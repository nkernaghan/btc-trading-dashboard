# Copy this to .env (or backend/.env for manual run) and fill in any keys you have.
# Every API key is OPTIONAL — the app runs without them; signals that need a paid
# source just won't populate.

# For Docker Compose, use the service hostname:
REDIS_URL=redis://redis:6379/0
# For manual run (redis installed via brew), use:
# REDIS_URL=redis://localhost:6379/0

SQLITE_PATH=data/btc_dashboard.db

# Derivatives / funding / liquidations
COINGLASS_API_KEY=
COINALYZE_API_KEY=

# On-chain
GLASSNODE_API_KEY=
CRYPTOQUANT_API_KEY=

# News / sentiment
NEWSAPI_KEY=

# Options flow
DERIBIT_CLIENT_ID=
DERIBIT_CLIENT_SECRET=

# Price data (higher rate limits)
COINGECKO_API_KEY=
